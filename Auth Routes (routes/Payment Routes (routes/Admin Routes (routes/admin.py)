from flask import Blueprint, request, jsonify
from app import db, Transaction, User
from sqlalchemy import func

bp = Blueprint('admin', __name__, url_prefix='/api/admin')

@bp.route('/transactions', methods=['GET'])
def get_transactions():
    """Get all transactions"""
    page = request.args.get('page', 1, type=int)
    per_page = request.args.get('per_page', 50, type=int)
    status_filter = request.args.get('status')
    
    query = Transaction.query
    
    if status_filter:
        query = query.filter_by(status=status_filter)
    
    transactions = query.order_by(Transaction.created_at.desc()).paginate(
        page=page,
        per_page=per_page
    )
    
    return jsonify({
        'transactions': [{
            'id': t.id,
            'user_id': t.user_id,
            'phone_number': t.phone_number,
            'amount': t.amount,
            'status': t.status,
            'receipt_code': t.mpesa_receipt_code,
            'created_at': t.created_at.isoformat(),
            'updated_at': t.updated_at.isoformat()
        } for t in transactions.items],
        'total': transactions.total,
        'pages': transactions.pages,
        'current_page': page
    }), 200

@bp.route('/statistics', methods=['GET'])
def get_statistics():
    """Get transaction statistics"""
    total_transactions = Transaction.query.count()
    total_amount = db.session.query(func.sum(Transaction.amount)).scalar() or 0
    completed_amount = db.session.query(func.sum(Transaction.amount)).filter_by(
        status='completed'
    ).scalar() or 0
    failed_count = Transaction.query.filter_by(status='failed').count()
    completed_count = Transaction.query.filter_by(status='completed').count()
    
    return jsonify({
        'total_transactions': total_transactions,
        'completed_transactions': completed_count,
        'failed_transactions': failed_count,
        'pending_transactions': total_transactions - completed_count - failed_count,
        'total_amount': float(total_amount),
        'completed_amount': float(completed_amount)
    }), 200
