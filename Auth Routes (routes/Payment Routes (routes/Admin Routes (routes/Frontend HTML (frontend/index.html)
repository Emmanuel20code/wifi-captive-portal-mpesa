<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WiFi Portal - M-Pesa Payment</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div class="container">
        <!-- Loading Spinner -->
        <div id="loading" class="spinner hidden"></div>

        <!-- Login Screen -->
        <div id="loginScreen" class="screen active">
            <div class="card">
                <div class="header">
                    <h1>🌐 WiFi Portal</h1>
                    <p>Connect and Pay with M-Pesa</p>
                </div>
                <form id="loginForm">
                    <div class="form-group">
                        <label for="phoneInput">Phone Number</label>
                        <input 
                            type="tel" 
                            id="phoneInput" 
                            placeholder="0712345678 or +254712345678"
                            required
                        >
                        <small>Kenya format (07xx or +254)</small>
                    </div>
                    <button type="submit" class="btn btn-primary">Continue</button>
                </form>
            </div>
        </div>

        <!-- Payment Screen -->
        <div id="paymentScreen" class="screen">
            <div class="card">
                <div class="header">
                    <h2>Complete Payment</h2>
                </div>
                <div class="payment-info">
                    <p><strong>Phone:</strong> <span id="displayPhone"></span></p>
                    <p><strong>Amount:</strong> <span id="displayAmount"></span> KES</p>
                </div>
                <form id="paymentForm">
                    <div class="form-group">
                        <label for="amountInput">Enter Amount (KES)</label>
                        <input 
                            type="number" 
                            id="amountInput" 
                            placeholder="100"
                            min="1"
                            required
                        >
                    </div>
                    <button type="submit" class="btn btn-primary">Pay with M-Pesa</button>
                    <button type="button" class="btn btn-secondary" onclick="goBack()">Back</button>
                </form>
            </div>
        </div>

        <!-- Payment Processing Screen -->
        <div id="processingScreen" class="screen">
            <div class="card">
                <div class="header">
                    <h2>Enter M-Pesa PIN</h2>
                </div>
                <div class="message info">
                    <p>A prompt has been sent to your phone</p>
                    <p id="processingPhone"></p>
                </div>
                <div id="statusMessage" class="message"></div>
                <div class="spinner"></div>
                <button type="button" class="btn btn-secondary" onclick="cancelPayment()">Cancel</button>
            </div>
        </div>

        <!-- Success Screen -->
        <div id="successScreen" class="screen">
            <div class="card">
                <div class="header success">
                    <h2>✓ Payment Successful</h2>
                </div>
                <div class="receipt">
                    <p><strong>Receipt Code:</strong> <span id="receiptCode"></span></p>
                    <p><strong>Amount:</strong> <span id="successAmount"></span> KES</p>
                    <p><strong>Time:</strong> <span id="successTime"></span></p>
                </div>
                <div class="message success">
                    <p>You now have WiFi access!</p>
                </div>
                <button type="button" class="btn btn-primary" onclick="location.reload()">Close</button>
            </div>
        </div>

        <!-- Error Screen -->
        <div id="errorScreen" class="screen">
            <div class="card">
                <div class="header error">
                    <h2>✗ Payment Failed</h2>
                </div>
                <div class="message error">
                    <p id="errorMessage">An error occurred. Please try again.</p>
                </div>
                <button type="button" class="btn btn-primary" onclick="goBack()">Try Again</button>
            </div>
        </div>
    </div>

    <script src="js/app.js"></script>
</body>
</html>
