const API_BASE = 'http://localhost:5000/api';

let currentUser = null;
let currentTransaction = null;

// Screen Navigation
function showScreen(screenId) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(screenId).classList.add('active');
}

function goBack() {
    currentUser = null;
    showScreen('loginScreen');
}

function cancelPayment() {
    currentTransaction = null;
    goBack();
}

// Login Form
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const phoneNumber = document.getElementById('phoneInput').value.trim();
    
    try {
        showLoading(true);
        const response = await fetch(`${API_BASE}/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone_number: phoneNumber })
        });
        
        if (!response.ok) throw new Error('Login failed');
        
        const data = await response.json();
        currentUser = data;
        
        document.getElementById('displayPhone').textContent = data.phone_number;
        document.getElementById('processingPhone').textContent = data.phone_number;
        
        showScreen('paymentScreen');
    } catch (error) {
        showError('Login failed: ' + error.message);
    } finally {
        showLoading(false);
    }
});

// Payment Form
document.getElementById('paymentForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const amount = document.getElementById('amountInput').value;
    
    document.getElementById('displayAmount').textContent = amount;
    
    try {
        showLoading(true);
        const response = await fetch(`${API_BASE}/payment/initiate`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                phone_number: currentUser.phone_number,
                amount: parseInt(amount),
                user_id: currentUser.user_id
            })
        });
        
        if (!response.ok) throw new Error('Payment initiation failed');
        
        const data = await response.json();
        currentTransaction = data;
        
        showScreen('processingScreen');
        pollPaymentStatus(data.transaction_id);
    } catch (error) {
        showError('Payment initiation failed: ' + error.message);
    } finally {
        showLoading(false);
    }
});

// Poll payment status
async function pollPaymentStatus(transactionId) {
    let attempts = 0;
    const maxAttempts = 120; // 2 minutes with 1-second polling
    
    const poll = setInterval(async () => {
        attempts++;
        
        try {
            const response = await fetch(`${API_BASE}/payment/status/${transactionId}`);
            const data = await response.json();
            
            if (data.status === 'completed') {
                clearInterval(poll);
                showSuccess(data);
            } else if (data.status === 'failed') {
                clearInterval(poll);
                showError('Payment was declined');
            } else if (attempts > maxAttempts) {
                clearInterval(poll);
                showError('Payment timeout. Please check your transaction status.');
            }
        } catch (error) {
            console.error('Error polling status:', error);
        }
    }, 1000);
}

// UI Helpers
function showLoading(visible) {
    document.getElementById('loading').classList.toggle('hidden', !visible);
}

function showSuccess(transaction) {
    document.getElementById('receiptCode').textContent = transaction.receipt_code || 'N/A';
    document.getElementById('successAmount').textContent = transaction.amount;
    document.getElementById('successTime').textContent = new Date().toLocaleString();
    showScreen('successScreen');
}

function showError(message) {
    document.getElementById('errorMessage').textContent = message;
    showScreen('errorScreen');
}

// Test credentials on load
window.addEventListener('load', async () => {
    try {
        const response = await fetch(`${API_BASE}/payment/test-credentials`);
        const data = await response.json();
        console.log('M-Pesa Credentials:', data);
    } catch (error) {
        console.error('Error testing credentials:', error);
    }
});
